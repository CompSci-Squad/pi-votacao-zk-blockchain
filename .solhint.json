{
  "extends": "solhint:recommended",
  "rules": {
    "compiler-version": ["error", "^0.8.24"],
    "func-visibility": ["warn", { "ignoreConstructors": true }],
    "no-empty-blocks": "off",
    "max-line-length": ["warn", 140],
    "no-inline-assembly": "off",
    "no-global-import": "off",
    "gas-custom-errors": "off"
  }
}
