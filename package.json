{
  "name": "pi-votacao-zk-blockchain",
  "version": "2.0.0",
  "description": "Sistema de votacao eletronica com ZK-SNARKs e Ethereum (Foundry + Mocha integration)",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "forge build",
    "test:forge": "forge test -vvv",
    "test:integration": "mocha --recursive test/integration --timeout 120000",
    "bench:circuit": "node scripts/bench_circuit.js",
    "smoke:docker": "bash ../scripts/docker_smoke.sh",
    "verify:artifacts": "bash scripts/verify_checksums.sh",
    "demo": "node scripts/demo.js",
    "demo:rich": "node scripts/demo_rich.js",
    "interact": "node scripts/interact.js",
    "sync:circuit": "bash scripts/sync_circuit_artifacts.sh"
  },
  "keywords": ["blockchain", "ethereum", "solidity", "foundry", "zk-snarks", "voting"],
  "author": "CompSci Squad",
  "license": "MIT",
  "devDependencies": {
    "chai": "^4.5.0",
    "ethers": "^6.13.4",
    "mocha": "^10.7.3"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.4.5",
    "ora": "^5.4.1",
    "snarkjs": "^0.7.4"
  }
}
